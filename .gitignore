# --- Rust & Cargo ---
# Generated build artifacts from compiling your Axum app
/target/

# Remove if you are building an application and want deterministic builds
# (Keep Cargo.lock for applications, ignore it only for libraries)
# Cargo.lock

# --- Environment & Secrets ---
# Configuration files containing sensitive API keys, database URLs, and passwords
.env
.env.*
!.env.example

# --- Operating System & IDEs ---
# macOS specific files
.DS_Store

# JetBrains IDEs (IntelliJ, RustRover)
.idea/
*.iml

# VS Code settings and local history
.vscode/
.history/

# --- Application Specific ---
# Log files generated by tracing-appender or other logging systems
*.log
/logs/
